# ─── Database (Postgres, e.g. Supabase) ──────────────────────────────────────
# Required. Paste the connection string from Supabase (Settings → Database →
# Connection string → URI). For local Postgres, use e.g.
#   postgresql://user:pass@localhost:5432/medicome
DATABASE_URL="postgresql://user:password@host:5432/dbname"
# DIRECT_URL — direct (non-pooled) connection used for migrations. On Supabase,
# DATABASE_URL is the pooled string (port 6543, ?pgbouncer=true) and DIRECT_URL
# is the direct string (port 5432). Locally, set both to the same value.
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Required. Secret used to sign the JWT stored in the session cookie. Must be
# at least 32 characters. Generate a strong one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-me-with-a-32-character-random-secret"

# ─── AI chat (server-side proxy) ─────────────────────────────────────────────
# Free-text chat is handled by /api/chat on the server (NOT the browser), so the
# key below is never exposed to clients. It speaks the plain Ollama API, which
# works against either Ollama Cloud (prod) or a local Ollama (dev).
#
# PROD — Ollama Cloud (free tier, no credit card): sign up at https://ollama.com,
# create an API key, and set:
#   OLLAMA_BASE_URL="https://api.ollama.com"   (this is also the default)
#   OLLAMA_API_KEY="<your-ollama-cloud-key>"   (required for cloud)
#   OLLAMA_MODEL="gpt-oss:20b"                 (pick any model your plan allows)
#
# LOCAL DEV — your own Ollama: leave OLLAMA_API_KEY unset and point at localhost.
# No OLLAMA_ORIGINS=* needed anymore — the call is server→Ollama, not browser.
#   OLLAMA_BASE_URL="http://127.0.0.1:11434"
#   OLLAMA_MODEL="llama3.2"
OLLAMA_BASE_URL="https://api.ollama.com"
OLLAMA_API_KEY="replace-with-your-ollama-cloud-api-key"
OLLAMA_MODEL="gpt-oss:20b"
